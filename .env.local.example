# Copy to .env.local and fill in real values. .env.local is gitignored.
# The lighting-engine FastAPI app + pytest conftest will load this file
# automatically (via python-dotenv) — no need to source it manually.

# Anthropic API key for the LLM brief layer (Phase 3, Step 5).
# Used by the live test (tests/brief/test_generator_live.py) and by the
# /api/projects/{pid}/rooms/{rid}/generate endpoint once Phase 7 wires the
# brief into the real generation pipeline.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the SQLite location for the FastAPI service.
# Default is ./data/state.db relative to lighting-engine/.
# LIGHTING_ENGINE_DB_URL=sqlite+aiosqlite:///data/state.db

# Optional: extra CORS origins for the FastAPI service (comma-separated).
# Localhost:3000 and *.vercel.app are always allowed.
# CORS_ALLOWED_ORIGINS=https://staging.example.com,https://nectar-studio.example.com
